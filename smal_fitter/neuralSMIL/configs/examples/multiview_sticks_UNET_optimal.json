{
  "mode": "multiview",

  "num_views_to_use": null,
  "min_views_per_sample": 2,
  "cross_attention_layers": 4,
  "cross_attention_heads": 8,
  "cross_attention_dropout": 0.05,

  "smal_model": {
    "smal_file": "3D_model_prep/SMILy_STICK.pkl",
    "shape_family": null
  },

  "dataset": {
    "data_path": "SMILySTICKS_centred_reprojected.h5",
    "train_ratio": 0.85,
    "val_ratio": 0.05,
    "test_ratio": 0.1,
    "dataset_fraction": 1.0
  },

  "model": {
    "backbone_name": "unet_efficientnet_b5",
    "freeze_backbone": true,
    "backbone_unfreeze_epoch": 30,
    "backbone_lr_multiplier": 0.05,
    "hidden_dim": 1024,
    "head_type": "transformer_decoder",
    "use_unity_prior": false,
    "rgb_only": false,
    "transformer_depth": 6,
    "transformer_heads": 8,
    "transformer_dim_head": 64,
    "transformer_mlp_dim": 1024,
    "transformer_dropout": 0.05,
    "transformer_ief_iters": 3,
    "transformer_trans_scale_factor": 0.01
  },

  "optimizer": {
    "learning_rate": 1e-4,
    "weight_decay": 1e-4,
    "gradient_clip_norm": 1.0,
    "optimizer_type": "adamw",
    "lr_schedule": {
      "0": 1e-4,
      "15": 5e-5,
      "30": 3e-5,
      "60": 1e-5,
      "120": 5e-6,
      "200": 2e-6,
      "300": 1e-6
    }
  },

  "loss_curriculum": {
    "base_weights": {
      "global_rot": 0.0,
      "joint_rot": 0.001,
      "betas": 0.0005,
      "trans": 0.0005,
      "fov": 0.001,
      "cam_rot": 0.01,
      "cam_trans": 0.01,
      "log_beta_scales": 0.0005,
      "betas_trans": 0.0005,
      "keypoint_2d": 0.1,
      "keypoint_3d": 0.25,
      "silhouette": 0.0,
      "joint_angle_regularization": 0.01,
      "limb_scale_regularization": 0.1,
      "limb_trans_regularization": 1,
      "triangulation_consistency": 0.0,
      "ief_intermediate": 0.05
    },
    "curriculum_stages": {
      "10": {
        "joint_angle_regularization": 1e-3,
        "limb_scale_regularization": 0.01,
        "limb_trans_regularization": 1
      },
      "20": {
        "keypoint_3d": 1,
        "joint_angle_regularization": 1e-4,
        "limb_scale_regularizationthe ": 0.001,
        "limb_trans_regularization": 0.5
      },
      "50": {
        "keypoint_3d": 2,
        "joint_angle_regularization": 1e-5,
        "limb_scale_regularization": 1e-4,
        "limb_trans_regularization": 0.5,
        "ief_intermediate": 0.1
      },
      "100": {
        "keypoint_3d": 2,
        "joint_angle_regularization": 1e-6,
        "limb_scale_regularization": 5e-6,
        "limb_trans_regularization": 0.0001,
        "ief_intermediate": 0.1
      },
      "150": {
        "keypoint_3d": 2,
        "joint_angle_regularization": 1e-7,
        "limb_scale_regularization": 1e-6,
        "limb_trans_regularization": 0.0001,
        "fov": 1e-7,
        "cam_rot": 1e-8,
        "cam_trans": 1e-8,
        "ief_intermediate": 0.05
      },
      "250": {
        "keypoint_3d": 2,
        "joint_angle_regularization": 1e-7,
        "limb_scale_regularization": 1e-6,
        "limb_trans_regularization": 0.00001,
        "fov": 1e-7,
        "cam_rot": 1e-8,
        "cam_trans": 1e-8,
        "ief_intermediate": 0.02
      }
    }
  },

  "scale_trans_beta": {
    "mode": "separate"
  },

  "mesh_scaling": {
    "allow_mesh_scaling": true,
    "init_mesh_scale": 1.0,
    "use_log_scale": true
  },

  "augmentation": {
    "enabled": true,
    "geometric_enabled": false,
    "color_jitter_brightness": 0.15,
    "color_jitter_contrast": 0.15,
    "color_jitter_saturation": 0.1,
    "gaussian_noise_std": 0.01,
    "gaussian_blur_prob": 0.1,
    "gaussian_blur_kernel_range": [3, 5],
    "random_erasing_prob": 0.1,
    "random_erasing_scale_range": [0.01, 0.06],
    "crop_jitter_fraction": 0.0,
    "scale_jitter_range": [0.9, 1.1]
  },

  "joint_importance": {
    "enabled": true,
    "important_joint_names": ["l_1_pt_l", "l_2_pt_l", "l_3_pt_l", "l_1_pt_r", "l_2_pt_r", "l_3_pt_r"],
    "weight_multiplier": 10.0
  },

  "ignored_joint_locations": {
    "enabled": true,
    "ignored_joint_names": []
  },

  "output": {
    "checkpoint_dir": "multiview_checkpoints_optimal_EffB5_ief3",
    "plots_dir": "multiview_plots_optimal_EffB5_ief3",
    "visualizations_dir": "multiview_visualizations_optimal_EffB5_ief3",
    "singleview_visualizations_dir": "multiview_singleview_renders_optimal_EffB5_ief3",
    "save_checkpoint_every": 10,
    "generate_visualizations_every": 5,
    "plot_history_every": 5,
    "num_visualization_samples": 5
  },

  "training": {
    "batch_size": 2,
    "num_epochs": 400,
    "seed": 42,
    "rotation_representation": "6d",
    "num_workers": 16,
    "pin_memory": true,
    "prefetch_factor": 8,
    "deterministic": false,
    "resume_checkpoint": null,
    "reset_ief_token_embedding": false,
    "use_gt_camera_init": true,
    "use_mixed_precision": true,
    "backbone_chunk_size": 4,
    "gradient_accumulation_steps": 4,
    "validate_every_n_epochs": 2
  }
}
